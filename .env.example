GEMINI_API_KEY=
QASCAN_MAX_PAGES=50
QASCAN_MAX_DEPTH=3
QASCAN_TIME_BUDGET_SECONDS=300
# Phase 2 — functional engine
QASCAN_HEAL_THRESHOLD=0.7
# QASCAN_CACHE_DIR=.qascan_cache
# Phase 3 — persistence
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/qascan
# Phase 4 — scheduler + alerting
QASCAN_DASHBOARD_URL=http://localhost:8501
# Email alerts (only needed if a suite has an "email" notify channel):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=qascan@localhost
# API / billing vars added in their phases
